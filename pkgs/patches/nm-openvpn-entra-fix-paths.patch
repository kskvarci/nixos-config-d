# Fix hardcoded openvpn/modprobe paths for the NixOS store.
# Written against the NetworkManager-openvpn entra_auth branch (1.12.5).
# @openvpn@ and @kmod@ are substituted by replaceVars in the derivation.
--- a/properties/nm-openvpn-editor.c
+++ b/properties/nm-openvpn-editor.c
@@ -993,10 +993,9 @@ static const char *
 nm_find_openvpn (void)
 {
 	static const char *openvpn_binary_paths[] = {
-		"/usr/sbin/openvpn",
-		"/sbin/openvpn",
+		"@openvpn@/bin/openvpn",
 		NULL
 	};
 	const char  **openvpn_binary = openvpn_binary_paths;
--- a/src/nm-openvpn-service.c
+++ b/src/nm-openvpn-service.c
@@ -613,12 +613,10 @@ static const char *
 openvpn_binary_find_exepath (void)
 {
 	static const char *paths[] = {
-		"/usr/sbin/openvpn",
-		"/sbin/openvpn",
-		"/usr/local/sbin/openvpn",
+		"@openvpn@/bin/openvpn",
 	};
 	int i;
 
@@ -2724,8 +2724,8 @@ main (int argc, char *argv[])
 	_LOGD ("nm-openvpn-service (version " DIST_VERSION ") starting...");
 
 	if (   !g_file_test ("/sys/class/misc/tun", G_FILE_TEST_EXISTS)
-	    && (system ("/sbin/modprobe tun") == -1))
+	    && (system ("@kmod@/bin/modprobe tun") == -1))
 		return EXIT_FAILURE;
 
 	plugin = nm_openvpn_plugin_new (bus_name);
